"""
timetable_loader.py — Trains at a Glance 2026 schedule data.
Provides per-station arrival/departure windows and journey time calculations.
"""

import logging
from dataclasses import dataclass, field
from datetime import datetime, timedelta, time as dtime
from typing import Dict, List, Optional, Tuple

from ml.config import TRAINS, CORRIDORS, TrainConfig

logger = logging.getLogger(__name__)


# ---------------------------------------------------------------------------
# Data classes
# ---------------------------------------------------------------------------

@dataclass
class StationStop:
    """A single stop in a train's timetable."""
    station_code: str
    station_name: str
    arrival: Optional[str]      # HH:MM or None (origin)
    departure: Optional[str]    # HH:MM or None (terminus)
    halt_min: int               # scheduled halt in minutes
    distance_km: float          # from origin
    day: int                    # journey day (1-indexed)


@dataclass
class TrainSchedule:
    """Full timetable for one train."""
    train_no: str
    train_name: str
    corridor: str
    origin: str
    destination: str
    stops: List[StationStop] = field(default_factory=list)
    days_of_run: List[str] = field(default_factory=list)

    def get_stop(self, station_code: str) -> Optional[StationStop]:
        return next((s for s in self.stops if s.station_code == station_code), None)

    def expected_arrival_at(self, station_code: str) -> Optional[str]:
        stop = self.get_stop(station_code)
        return stop.arrival if stop else None

    def expected_departure_from(self, station_code: str) -> Optional[str]:
        stop = self.get_stop(station_code)
        return stop.departure if stop else None

    def journey_minutes_between(self, from_code: str, to_code: str) -> Optional[int]:
        """Calculate scheduled journey minutes between two stations."""
        from_stop = self.get_stop(from_code)
        to_stop = self.get_stop(to_code)
        if not from_stop or not to_stop:
            return None
        dep = _parse_hhmm(from_stop.departure)
        arr = _parse_hhmm(to_stop.arrival)
        if not dep or not arr:
            return None
        delta = (arr - dep).total_seconds() / 60
        # Add day offset
        day_diff = (to_stop.day - from_stop.day) * 1440
        return int(delta + day_diff) if delta + day_diff >= 0 else int(delta + day_diff + 1440)


def _parse_hhmm(t: Optional[str]) -> Optional[datetime]:
    if not t:
        return None
    try:
        return datetime.strptime(t, "%H:%M")
    except ValueError:
        return None


def _add_minutes(t: str, mins: int) -> str:
    """Add minutes to HH:MM string, wrapping at midnight."""
    try:
        base = datetime.strptime(t, "%H:%M")
        result = base + timedelta(minutes=mins)
        return result.strftime("%H:%M")
    except ValueError:
        return t


