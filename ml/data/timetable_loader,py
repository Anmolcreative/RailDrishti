# ---------------------------------------------------------------------------
# Timetable loader
# ---------------------------------------------------------------------------

class TimetableLoader:
    """Manages train schedules and provides lookup utilities."""

    def __init__(self):
        self._schedules: Dict[str, TrainSchedule] = {}
        self._built = False

    def build(self) -> "TimetableLoader":
        """Build schedule registry from built-in + config data."""
        self._load_from_data()
        self._load_from_config()
        self._built = True
        logger.info(f"TimetableLoader built: {len(self._schedules)} schedules loaded")
        return self

    def _load_from_data(self):
        """Load detailed stop-by-stop schedules from _SCHEDULE_DATA."""
        for train_no, stop_tuples in _SCHEDULE_DATA.items():
            train_cfg = TRAINS.get(train_no)
            stops = [
                StationStop(
                    station_code=t[0], station_name=t[1],
                    arrival=t[2], departure=t[3], halt_min=t[4],
                    distance_km=float(t[5]), day=t[6],
                )
                for t in stop_tuples
            ]
            self._schedules[train_no] = TrainSchedule(
                train_no=train_no,
                train_name=train_cfg.name if train_cfg else train_no,
                corridor=train_cfg.corridor if train_cfg else "unknown",
                origin=stops[0].station_code if stops else "",
                destination=stops[-1].station_code if stops else "",
                stops=stops,
                days_of_run=train_cfg.days if train_cfg else ["Daily"],
            )

    def _load_from_config(self):
        """Load trains from config that don't have detailed stop data."""
        for train_no, train_cfg in TRAINS.items():
            if train_no in self._schedules:
                continue
            corridor = CORRIDORS.get(train_cfg.corridor)
            if not corridor:
                continue
            stops = self._generate_stops(train_cfg, corridor)
            self._schedules[train_no] = TrainSchedule(
                train_no=train_no,
                train_name=train_cfg.name,
                corridor=train_cfg.corridor,
                origin=train_cfg.origin,
                destination=train_cfg.destination,
                stops=stops,
                days_of_run=train_cfg.days,
            )

    @staticmethod
    def _generate_stops(
        train_cfg: TrainConfig, corridor: "CorridorConfig"
    ) -> List[StationStop]:
        """
        Generate approximate stop sequence by interpolating between
        origin departure and destination arrival.
        """
        stations = corridor.stations
        n = len(stations)
        if n == 0:
            return []

        dep = _parse_hhmm(train_cfg.departure) or datetime.strptime("00:00", "%H:%M")
        arr = _parse_hhmm(train_cfg.arrival) or datetime.strptime("12:00", "%H:%M")

        # Handle overnight trains
        if arr <= dep:
            arr += timedelta(days=1)
        total_mins = (arr - dep).total_seconds() / 60

        step = total_mins / max(n - 1, 1)
        stops = []
        total_dist = corridor.total_distance_km
        dist_step = total_dist / max(n - 1, 1)

        for i, stn_code in enumerate(stations):
            elapsed = step * i
            t = dep + timedelta(minutes=elapsed)
            is_origin = (i == 0)
            is_dest = (i == n - 1)
            stops.append(StationStop(
                station_code=stn_code,
                station_name=stn_code,
                arrival=None if is_origin else t.strftime("%H:%M"),
                departure=None if is_dest else t.strftime("%H:%M"),
                halt_min=0 if (is_origin or is_dest) else 2,
                distance_km=round(dist_step * i, 1),
                day=1 + int(elapsed // 1440),
            ))
        return stops

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------

    def get_schedule(self, train_no: str) -> Optional[TrainSchedule]:
        return self._schedules.get(train_no)

    def all_schedules(self) -> Dict[str, TrainSchedule]:
        return dict(self._schedules)

    def trains_at_station(self, station_code: str) -> List[TrainSchedule]:
        """Return all trains that stop at the given station."""
        return [
            s for s in self._schedules.values()
            if any(stop.station_code == station_code for stop in s.stops)
        ]

    def expected_at(
        self, station_code: str, window_minutes: int = 120
    ) -> List[Dict]:
        """
        Return list of trains expected at station_code in next window_minutes.
        Each entry: {train_no, name, arrival, departure, halt_min}
        """
        now = datetime.now()
        current_hhmm = now.strftime("%H:%M")
        result = []
        for schedule in self.trains_at_station(station_code):
            stop = schedule.get_stop(station_code)
            if not stop:
                continue
            arr = stop.arrival or stop.departure
            if not arr:
                continue
            arr_dt = _parse_hhmm(arr)
            if not arr_dt:
                continue
            now_dt = _parse_hhmm(current_hhmm)
            if not now_dt:
                continue
            diff = (arr_dt - now_dt).total_seconds() / 60
            if -10 <= diff <= window_minutes:
                result.append({
                    "train_no": schedule.train_no,
                    "name": schedule.train_name,
                    "arrival": stop.arrival,
                    "departure": stop.departure,
                    "halt_min": stop.halt_min,
                    "distance_from_origin": stop.distance_km,
                })
        return sorted(result, key=lambda x: x["arrival"] or x["departure"] or "")

    def corridor_trains(self, corridor_key: str) -> List[TrainSchedule]:
        return [s for s in self._schedules.values() if s.corridor == corridor_key]

    def count(self) -> int:
        return len(self._schedules)


# ---------------------------------------------------------------------------
# Singleton
# ---------------------------------------------------------------------------
_loader: Optional[TimetableLoader] = None


def get_timetable_loader() -> TimetableLoader:
    global _loader
    if _loader is None:
        _loader = TimetableLoader().build()
    return _loader